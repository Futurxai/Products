{
  "name": "eatwell-testing",
  "version": "1.0.0",
  "description": "Test automation suite for EatWell4U",
  "scripts": {
    "test": "karma start karma.conf.js",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "test:ci": "karma start karma.conf.js --single-run --browsers ChromeHeadless && cypress run",
    "test:coverage": "karma start karma.conf.js --single-run --code-coverage"
  },
  "devDependencies": {
    "@types/jasmine": "~5.1.0",
    "cypress": "^13.0.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.0"
  }
}
