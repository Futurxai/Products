rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Love Digitally published pages — public read, public create, no edit/delete
    match /lovedigitally_pages/{pageId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(['tpl', 'data', 'createdAt'])
        && request.resource.data.tpl is string
        && request.resource.data.tpl in ['love', 'proposal', 'quiz', 'slides', 'album', 'countdown']
        && request.resource.data.data is map
        && request.resource.data.createdAt is timestamp;

      allow update, delete: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
