rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Love Digitally pages — public read, writes ONLY via Cloud Function (Admin SDK bypasses rules)
    match /lovedigitally_pages/{pageId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Subscription / order records — server-only writes, no client read
    match /lovedigitally_subscriptions/{id} {
      allow read, write: if false;
    }
    match /lovedigitally_orders/{id} {
      allow read, write: if false;
    }
    match /lovedigitally_webhook_events/{id} {
      allow read, write: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
